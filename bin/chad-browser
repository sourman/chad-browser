#!/usr/bin/env bash
# chad-browser — isolated, ephemeral Chromium instances seeded from your testing base.
#
# The dream: every agent gets its OWN Chromium on its OWN port with its OWN throw-away
# profile — but seeded from your base profile (~/.config/chromium) which already holds
# your logins. No agent re-does auth; no two agents fight over the same port/tab/profile.
#
# Each `up` copies your base into a fresh --user-data-dir (WAL-safe on the live cookie
# DBs) and opens CDP on 127.0.0.1 on a free port. `down` kills it and removes the dir.
#
# Uses `chromium` (NOT google-chrome — that stays your daily driver, untouched).
#
#   chad-browser up [opts] [URLs...] [-- chromium-flag...]
#                                       launch an isolated, pre-authenticated browser
#   chad-browser down <port|name|pid>   stop it + remove its ephemeral profile
#   chad-browser list                   running agent browsers (with drive hints)
#   chad-browser cdp  <port|name|pid>   print the browser websocket endpoint
#   chad-browser eval [--id|--name <id>] [--page] [--wait '<check>']
#                     [--stdin|--file <f>|'<js>']   run JS against the page
#   chad-browser script [--id|--name <id>] [--page] [--wait '<check>'] <f>
#                                       run a JS file against the page
#   chad-browser repl [--id|--name <id>]          interactive JS prompt
#   chad-browser probe <url>            find a live server (supports {8080..8090} ranges)
#   chad-browser gc                     reap profiles whose process is gone
#   chad-browser info                   resolved base/binary/port-range/driver
#
# eval flags:
#   --id|--name <id>  target instance (alias; either works)
#   --page            run JS in the page context (document.querySelector works directly)
#   --wait '<check>'  poll a page JS expr until truthy, then run the body (composes with --page)
#   --stdin           read JS from stdin (pipe a heredoc — avoids shell-quoting hell)
#   --file <path>     read JS from a file
#   --timeout <ms>    eval body timeout (default 120000, capped 600000)
#
# up opts:
#   --name NAME      label (default: chad-<port>)
#   --port N         force a port (else first free in CB_PORT_MIN..MAX)
#   --headless       no window (or set CB_HEADLESS=1)
#   --headed         force a window (overrides CB_HEADLESS=1)
#   --store STORE    --password-store value; default = inherit base (don't pass flag)
#   --json           emit JSON instead of KEY=VAL
#
# Env: CHAD_BROWSER_BASE (default ~/.config/chromium)
#      CHAD_BROWSER_BIN  (default chromium)
#      CB_PORT_MIN / CB_PORT_MAX (default 9300 / 9499)
#      CB_HEADLESS (default unset = headed)
#
# Distinct from the Vercel `agent-browser` npm package and from any IDE built-in
# browser tool — this is a custom local bash script; nothing is installed via npm.

set -uo pipefail

BASE="${CHAD_BROWSER_BASE:-$HOME/.config/chromium}"
BIN="${CHAD_BROWSER_BIN:-chromium}"
CACHEDIR="${XDG_CACHE_HOME:-$HOME/.cache}/chad-browser"
RUNDIR="$CACHEDIR/run"
MEMORY_DIR="$CACHEDIR/memory"
EPHEM_ROOT="${TMPDIR:-/tmp}/chad-browser"
SOCKDIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/chad-browser"
# driver.mjs lives next to this script at <prefix>/lib/driver.mjs (consolidated
# repo layout) or <prefix>/lib/chad-browser/driver.mjs (flat ~/.local layout).
# Resolve through symlinks so a symlinked install finds the repo layout.
_self_dir="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
if [[ -f "$_self_dir/../lib/driver.mjs" ]]; then
  DRIVER="$_self_dir/../lib/driver.mjs"
elif [[ -f "$_self_dir/../lib/chad-browser/driver.mjs" ]]; then
  DRIVER="$_self_dir/../lib/chad-browser/driver.mjs"
elif [[ -f "$_self_dir/lib/chad-browser/driver.mjs" ]]; then
  DRIVER="$_self_dir/lib/chad-browser/driver.mjs"
else
  DRIVER="$HOME/.local/lib/chad-browser/driver.mjs"
fi
CB_PORT_MIN="${CB_PORT_MIN:-9300}"
CB_PORT_MAX="${CB_PORT_MAX:-9499}"

die() { echo "chad-browser: $*" >&2; exit 1; }

ensure_dirs() { mkdir -p "$CACHEDIR" "$RUNDIR" "$MEMORY_DIR" "$EPHEM_ROOT" "$SOCKDIR"; }

# Copy the base profile into an ephemeral dir. The auth SQLite DBs are snapshotted with
# `sqlite3 .backup` so a live base (rows still in *-wal) is captured consistently; their
# -wal/-shm siblings are then dropped so Chromium opens a clean file.
copy_base_to() {
  local src=$1 dst=$2 db
  cp -a "$src/Default" "$dst/Default"
  cp -a "$src/Local State" "$dst/Local State" 2>/dev/null || true
  [[ -e "$src/First Run" ]] && cp -a "$src/First Run" "$dst/First Run"
  for db in Cookies "Login Data" "Login Data For Account"; do
    [[ -f "$src/Default/$db" ]] || continue
    if sqlite3 "$src/Default/$db" ".backup '$dst/Default/$db'" 2>/dev/null; then
      rm -f "$dst/Default/$db-wal" "$dst/Default/$db-shm"
    fi
  done
  strip_transient "$dst"
}

# Drop lock/session/cache files so the clone starts clean and never claims to be "in use".
strip_transient() {
  local root=$1 d
  rm -f "$root"/SingletonLock "$root"/SingletonCookie "$root"/SingletonSocket \
        "$root"/DevToolsActivePort "$root"/LOCK 2>/dev/null || true
  d="$root/Default"; [[ -d "$d" ]] || return 0
  rm -f "$d"/LOCK "$d"/LOG "$d"/LOG.old \
        "$d"/"Current Session" "$d"/"Current Tabs" "$d"/"Last Session" "$d"/"Last Tabs" 2>/dev/null || true
  rm -rf "$d"/Sessions "$d"/Cache "$d"/"Code Cache" "$d"/GPUCache \
         "$d"/DawnGraphiteCache "$d"/DawnWebGPUCache "$d"/"Service Worker" \
         "$d"/"Download Service" 2>/dev/null || true
}

pick_free_port() {
  local p res
  for ((p=CB_PORT_MIN; p<=CB_PORT_MAX; p++)); do
    # Atomic reservation: mkdir succeeds for exactly one concurrent caller on
    # the same filesystem. This closes the TOCTOU where two `up` calls both
    # passed the old `[[ -e ... ]]` check before either wrote the runfile.
    # The reserve dir is cleaned up by the caller on both success and failure.
    mkdir "$RUNDIR/.reserve-$p" 2>/dev/null || continue
    res=$(python3 - "$p" <<'PY' 2>/dev/null
import socket, sys
s = socket.socket(); s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
try: s.bind(("127.0.0.1", int(sys.argv[1]))); print("free")
except OSError: print("busy")
finally: s.close()
PY
)
    if [[ "$res" == "free" ]]; then
      echo "$p"
      return 0
    fi
    # Port busy on the socket side — release the reservation and keep scanning.
    rmdir "$RUNDIR/.reserve-$p" 2>/dev/null || true
  done
  return 1
}

wait_for_cdp() {
  local port=$1 i
  for ((i=0; i<200; i++)); do
    curl -fsS "http://127.0.0.1:$port/json/version" >/dev/null 2>&1 && return 0
    sleep 0.1
  done
  return 1
}

# Wait for the driver's Unix socket to accept connections. The driver prints
# "driver ready" to stdout once listening; we read until we see it (or timeout).
wait_for_driver() {
  local sock=$1 driver_pid=$2 i
  for ((i=0; i<100; i++)); do
    [[ -S "$sock" ]] && return 0
    [[ -n "$driver_pid" ]] && ! kill -0 "$driver_pid" 2>/dev/null && return 1
    sleep 0.1
  done
  return 1
}

ws_endpoint() { curl -fsS "http://127.0.0.1:$1/json/version" 2>/dev/null | python3 -c 'import sys,json;print(json.load(sys.stdin)["webSocketDebuggerUrl"])' 2>/dev/null; }

resolve_id() {  # echo runfile path for port|name|pid
  local id=$1 f
  [[ -e "$RUNDIR/$id.env" ]] && { echo "$RUNDIR/$id.env"; return 0; }
  for f in "$RUNDIR"/*.env; do
    [[ -e "$f" ]] || continue
    if grep -qE "^(NAME=$id|PID=$id)\$" "$f"; then echo "$f"; return 0; fi
  done
  return 1
}

cmd_up() {
  local name="" port="" store="" app="" json=0 urls=() raw=()
  local headless=${CB_HEADLESS:-0}
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)  name=$2; shift 2;;
      --port)  port=$2; shift 2;;
      --store) store=$2; shift 2;;
      --app)   app=$2; shift 2;;
      --headless) headless=1; shift;;
      --headed)   headless=0; shift;;
      --json)  json=1; shift;;
      --)      shift; raw=("$@"); break;;
      -*)      die "unknown option '$1' (see: chad-browser --help)";;
      *)       urls+=("$1"); shift;;
    esac
  done
  # Chromium refuses multiple URLs in headless mode ("Multiple targets are not
  # supported in headless mode") and exits immediately, which surfaces only as a
  # generic "CDP didn't come up" after the full launch timeout. Fail fast with a
  # specific message instead. (Workaround: pass one URL, open the rest via
  # Target.createTarget after launch.)
  if [[ $headless -eq 1 && ${#urls[@]} -gt 1 ]]; then
    die "multiple URLs are not supported with --headless (Chromium limitation); pass one URL and open more tabs via Target.createTarget after launch"
  fi
  ensure_dirs
  [[ -d "$BASE/Default" ]] || die "base profile not found at $BASE (set CHAD_BROWSER_BASE)"
  command -v "$BIN" >/dev/null 2>&1 || die "binary '$BIN' not found (set CHAD_BROWSER_BIN)"

  [[ -n "$port" ]] || port=$(pick_free_port) || die "no free port in $CB_PORT_MIN-$CB_PORT_MAX (see: chad-browser list)"
  [[ -e "$RUNDIR/$port.env" ]] && die "port $port already in use by a tracked browser"
  [[ -z "$name" ]] && name="chad-$port"
  # Name flows into a runfile that is `source`d, a socket path, and a profile dir
  # that gets `rm -rf`d on down. Reject anything that isn't a safe label.
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]] \
    || die "invalid --name '$name': use letters, digits, ., _, - (max 64 chars), starting alphanumeric"
  # --app tags the instance for the memory hook (chad-browser remember/recall).
  # Same charset as --name (it's used as a filename under ~/.cache/chad-browser/memory).
  if [[ -n "$app" ]]; then
    [[ "$app" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]] \
      || die "invalid --app '$app': use letters, digits, ., _, - (max 64 chars), starting alphanumeric"
  fi
  # Reject a name already in use by a live instance. Two instances sharing a name
  # would share a socket path — the second silently hijacks the name and orphans
  # the first (its eval calls would route to the wrong browser). `list` to see them.
  local existing
  if existing=$(resolve_id "$name" 2>/dev/null); then
    die "name '$name' is already in use by a live instance (run: chad-browser list, then chad-browser down $name)"
  fi

  # Reserve the port atomically before any slow work (profile copy, Chromium
  # launch) so concurrent `up` calls don't double-allocate. The placeholder is
  # overwritten with the full record once the browser + driver are up. If `up`
  # fails after this point, the cleanup paths remove it.
  cat > "$RUNDIR/$port.env" <<EOF
PORT=$port
NAME=$name
PID=
PROFILE=
BASE=$BASE
WS=
SHELL_PID=$PPID
DRIVER_PID=
SOCKET=
APP=$app
RESERVED=1
EOF

  local prof="$EPHEM_ROOT/$name-$port"
  rm -rf "$prof"; mkdir -p "$prof"
  copy_base_to "$BASE" "$prof"

  local args=( --user-data-dir="$prof" --remote-debugging-port="$port"
               --no-first-run --no-default-browser-check --no-pings
               --disable-background-timer-throttling --disable-backgrounding-occluded-windows
               --disable-renderer-backgrounding --disable-features=Translate )
  [[ -n "$store" ]] && args+=( --password-store="$store" )
  [[ $headless -eq 1 ]] && args+=( --headless=new )
  [[ ${#raw[@]} -gt 0 ]] && args+=( "${raw[@]}" )
  [[ ${#urls[@]} -gt 0 ]] && args+=( "${urls[@]}" )

  "$BIN" "${args[@]}" >/dev/null 2>&1 &
  local pid=$!
  disown 2>/dev/null || true

  if ! wait_for_cdp "$port"; then
    pkill -f "user-data-dir=$prof" 2>/dev/null || true
    kill -9 "$pid" 2>/dev/null || true
    rm -rf "$prof" "$RUNDIR/$port.env"
    rmdir "$RUNDIR/.reserve-$port" 2>/dev/null || true
    die "Chromium CDP didn't come up on port $port"
  fi
  local ws; ws=$(ws_endpoint "$port")

  # Spawn the driver daemon. It connects to Chromium's WS and serves JS eval
  # over a Unix socket so the agent never touches CDP wiring directly.
  local sock="$SOCKDIR/$name.sock"
  rm -f "$sock"
  local driver_log="$CACHEDIR/$name-driver.log"
  if [[ -f "$DRIVER" ]]; then
    node "$DRIVER" "$ws" "$sock" >"$driver_log" 2>&1 &
    local driver_pid=$!
    disown 2>/dev/null || true
    if ! wait_for_driver "$sock" "$driver_pid"; then
      pkill -f "user-data-dir=$prof" 2>/dev/null || true
      kill -9 "$pid" 2>/dev/null || true
      kill "$driver_pid" 2>/dev/null || true
      rm -rf "$prof" "$sock" "$RUNDIR/$port.env"
      rmdir "$RUNDIR/.reserve-$port" 2>/dev/null || true
      die "driver daemon didn't come up (see $driver_log)"
    fi
  else
    # Driver not installed — fall back to raw-CDP mode (WS still works).
    driver_pid=""
    sock=""
  fi

  # SHELL_PID records the launching shell (PPID, not $$ which is this script's
  # own ephemeral PID) so per-shell instance resolution works: an agent's
  # eval/script calls walk up their process tree and match this shell.
  cat > "$RUNDIR/$port.env" <<EOF
PORT=$port
NAME=$name
PID=$pid
PROFILE=$prof
BASE=$BASE
WS=$ws
SHELL_PID=$PPID
DRIVER_PID=$driver_pid
SOCKET=$sock
APP=$app
EOF
  # The real runfile is committed; the atomic reserve dir is now redundant.
  rmdir "$RUNDIR/.reserve-$port" 2>/dev/null || true

  if [[ $json -eq 1 ]]; then
    python3 - "$port" "$name" "$pid" "$prof" "$ws" "$sock" "$driver_pid" <<'PY'
import json, sys
port, name, pid, prof, ws, sock, dpid = sys.argv[1:8]
print(json.dumps({"port": int(port), "name": name, "pid": int(pid),
                   "http": f"http://127.0.0.1:{port}", "ws": ws, "profile": prof,
                   "socket": sock, "driver_pid": int(dpid) if dpid else None}))
PY
  else
    echo "PORT=$port"
    echo "NAME=$name"
    echo "PID=$pid"
    echo "HTTP=http://127.0.0.1:$port"
    echo "WS=$ws"
    echo "PROFILE=$prof"
    [[ -n "$sock" ]] && echo "SOCKET=$sock"
    echo
    if [[ -n "$sock" ]]; then
      echo "→ driver on $sock  (drive: chad-browser eval --name $name '<js>')"
    else
      echo "→ CDP live at http://127.0.0.1:$port  (driver not installed; raw CDP only)"
    fi
    echo "→ teardown: chad-browser down $name"
  fi
}

cmd_down() {
  local id=${1:-}; [[ -n "$id" ]] || die "usage: chad-browser down <port|name|pid>"
  local f; f=$(resolve_id "$id") || die "no agent browser matching '$id'"
  # shellcheck disable=SC1090
  source "$f"
  # Kill the driver first so eval calls fail fast rather than hang on the socket.
  [[ -n "${DRIVER_PID:-}" ]] && kill "$DRIVER_PID" 2>/dev/null || true
  # Also reap any wedged driver still bound to this socket (e.g. an infinite-loop
  # eval body that outlived its runfile). pkill by the socket path is specific.
  [[ -n "${SOCKET:-}" ]] && { pkill -f "driver.mjs.*${SOCKET}" 2>/dev/null || true; rm -f "$SOCKET" 2>/dev/null || true; }
  pkill -f "user-data-dir=$PROFILE" 2>/dev/null || true
  kill "$PID" 2>/dev/null || true
  local i
  for ((i=0; i<40; i++)); do pgrep -f "user-data-dir=$PROFILE" >/dev/null 2>&1 || break; sleep 0.1; done
  pkill -9 -f "user-data-dir=$PROFILE" 2>/dev/null || true
  rm -rf "$PROFILE"; rm -f "$f"
  echo "stopped $NAME (port $PORT)"
}

cmd_list() {
  ensure_dirs
  local f any=0
  printf '%-6s %-18s %-8s %-6s %-7s %-12s %s\n' PORT NAME PID ALIVE DRIVER APP PROFILE
  for f in "$RUNDIR"/*.env; do
    [[ -e "$f" ]] || continue; any=1
    # shellcheck disable=SC1090
    ( source "$f"
      local alive=no driver=no
      kill -0 "$PID" 2>/dev/null && alive=yes
      [[ -n "${DRIVER_PID:-}" ]] && kill -0 "$DRIVER_PID" 2>/dev/null && driver=yes
      printf '%-6s %-18s %-8s %-6s %-7s %-12s %s\n' "$PORT" "$NAME" "$PID" "$alive" "$driver" "${APP:-}" "$PROFILE"
      # Only show drive hints for chad-browser-spawned instances (PROFILE under EPHEM_ROOT).
      # Externally-attached browsers (e.g. the daily-driver 9222 "attach") have an empty
      # PROFILE — never invite an agent to drive them; that's a safety footgun.
      [[ "$alive" == "yes" && "$driver" == "yes" && -n "$PROFILE" && "$PROFILE" == "$EPHEM_ROOT"/* ]] \
        && printf '         → drive: chad-browser eval --name %s ...\n' "$NAME" ) || true
  done
  [[ $any -eq 0 ]] && echo "(none)"
  return 0
}

cmd_cdp() {
  local id=${1:-}; [[ -n "$id" ]] || die "usage: chad-browser cdp <port|name|pid>"
  local f; f=$(resolve_id "$id") || die "no agent browser matching '$id'"
  # shellcheck disable=SC1090
  source "$f"
  ws_endpoint "$PORT"
}

# Resolve "my" instance — the one whose launching shell is an ancestor of $$
# (the current shell). Walks PPID up the tree. Falls back to the most recent
# instance if exactly one exists. Errors if multiple candidates exist with no
# ancestor match (ambiguous — name one explicitly).
resolve_mine() {
  local f shell_pid my_pid ppid_chain=()
  my_pid=$$
  # collect ancestor PIDs up the tree
  local p=$my_pid
  while [[ "$p" -gt 1 ]]; do
    ppid_chain+=("$p")
    p=$(awk '/^PPid:/{print $2}' /proc/$p/status 2>/dev/null) || break
    [[ -z "$p" ]] && break
  done
  local matches=()
  for f in "$RUNDIR"/*.env; do
    [[ -e "$f" ]] || continue
    shell_pid=$(grep -E '^SHELL_PID=' "$f" | cut -d= -f2)
    [[ -z "$shell_pid" ]] && continue
    for a in "${ppid_chain[@]}"; do
      if [[ "$a" == "$shell_pid" ]]; then
        matches+=("$f")
        break
      fi
    done
  done
  if [[ ${#matches[@]} -eq 1 ]]; then echo "${matches[0]}"; return 0; fi
  # no ancestor match — fall back to "only one SPAWNED instance" heuristic.
  # Skip externally-attached browsers (empty PROFILE) — never auto-drive those.
  local all=()
  for f in "$RUNDIR"/*.env; do
    [[ -e "$f" ]] || continue
    local prof; prof=$(grep -E '^PROFILE=' "$f" | cut -d= -f2-)
    [[ -n "$prof" && "$prof" == "$EPHEM_ROOT"/* ]] && all+=("$f")
  done
  if [[ ${#all[@]} -eq 1 ]]; then echo "${all[0]}"; return 0; fi
  if [[ ${#all[@]} -eq 0 ]]; then echo "no running chad-browser instances" >&2; return 1; fi
  echo "multiple chad-browser instances running; name one explicitly:" >&2
  for f in "${all[@]}"; do
    # shellcheck disable=SC1090
    ( source "$f"; echo "  $NAME (port $PORT)" ) >&2
  done
  return 1
}

resolve_socket() {
  local id=${1:-} f
  if [[ -z "$id" ]]; then f=$(resolve_mine) || die "specify an instance"
  else f=$(resolve_id "$id") || die "no agent browser matching '$id'"; fi
  # shellcheck disable=SC1090
  source "$f"
  # Safety guard: never let an agent drive an externally-attached browser (e.g. the
  # daily-driver 9222 "attach"). These have an empty PROFILE (not spawned by us).
  # Driving them executes JS in the user's real browser — reading real sessions,
  # triggering real actions. That violates the tool's isolation premise.
  if [[ -z "${PROFILE:-}" || "$PROFILE" != "$EPHEM_ROOT"/* ]]; then
    die "refusing to drive '$NAME': it is an externally-attached browser (not a chad-browser-spawned instance). Use a spawned instance instead."
  fi
  [[ -n "${SOCKET:-}" && -S "$SOCKET" ]] || die "no driver socket for $NAME (driver not installed? raw CDP at http://127.0.0.1:$PORT)"
  echo "$SOCKET"
}

# Resolve the runfile path for an instance id (or "mine" if empty). Used by the
# memory hook to read APP= without re-sourcing the whole file.
resolve_runfile_for() {
  local id=${1:-}
  if [[ -z "$id" ]]; then
    resolve_mine 2>/dev/null || return 1
  else
    resolve_id "$id" 2>/dev/null || return 1
  fi
}

# Send one JSON request over the Unix socket, read one newline-delimited response.
# Usage: chad-browser eval [--id <name|port>] [--page] [--stdin|--file <f>|'<js>']
cmd_eval() {
  local id="" code="" timeout="" page=0 from_stdin=0 wait="" wait_set=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id|--name|-n) id=$2; shift 2;;
      --timeout|-t) timeout=$2; shift 2;;
      --page) page=1; shift;;
      --stdin) from_stdin=1; shift;;
      --file) from_stdin=0; code=$(<"$2"); shift 2;;
      --wait) wait=$2; wait_set=1; shift 2;;
      --help|-h)
        cat <<'HELP'
chad-browser eval [--id <name|port|pid>] [--timeout <ms>] [--page] [--wait '<check>']
                  [--stdin | --file <path> | '<js>']

Runs JS connected to the page. The body is wrapped in an async function — use
`await` freely and `return` the result.

Modes (pick one source; default is the positional '<js>'):
  '<js>'            inline JS body (one-liners only — shell-quoting gets hostile fast)
  --file <path>     read JS from a file (or FIFO / process substitution)
  --stdin           read JS from stdin (pipe a heredoc — zero escaping pain)

Contexts:
  default          run in the Node driver context with the full helper surface below.
  --page           run in the PAGE context. `document.querySelector(...)` works directly.
                   The body is auto-wrapped in evalInPage(() => { ... }) with IIFE detection.
                   Combine with --stdin/--file for multi-statement page scripts.
  --wait '<check>' poll a page JS expression until truthy, THEN run the body. Composes
                   with --page: the wait runs in the driver, the body runs in the page.
                   Kills the most-repeated boilerplate:
                     await waitForDomStable(...); return await evalInPage(...)
                   → instead:
                     eval --page --wait 'document.querySelector("table tr")' --stdin

In scope (default Node context — no imports needed):
  session.<Domain>.<Method>(params)   full raw CDP surface
  evalInPage(jsExpr)                  Runtime.evaluate, returns value directly
  navigate(url, {timeout?, hint?})    Page.navigate + wait for readyState 'complete'
  typeInto(selector, text, {delay?})  focus + select-all + delete + insertText
  resetInterception()                 disable Fetch/Network interception (un-wedge after block)
  waitForReady({ check, timeout?, hint? })   poll a page JS expr until truthy
  waitForDomStable({ timeout?, hint? })      wait until DOM node count stabilizes (3 samples)
  onEvent(method, fn)                 subscribe to a CDP event; returns unsub fn
  captureRequests(urlPattern, fn, {body?, timeout?})  capture matching network traffic
  listPageTargets()                   page targets from Target.getTargets
  use(targetId)                       switch the active page target (iframes/tabs)

In --page context the helpers are NOT in scope — only `document`, `window`, etc.
(Use --wait to hydrate first, then read in page context.)

Options:
  --timeout <ms>   eval body timeout in ms (default 120000; capped at 600000)
                   also sets the client socket timeout to match.

Reply: a single JSON line, {"value": ...} or {"error": "...", "stack": "..."}.
HELP
        return 0
        ;;
      *)       code="$1"; shift;;
    esac
  done
  # Read JS from the chosen source.
  if [[ $from_stdin -eq 1 ]]; then
    code=$(cat)
  fi
  [[ -n "$code" ]] || die "usage: chad-browser eval [--id <name|port|pid>] [--page] [--wait '<check>'] [--timeout <ms>] (--stdin | --file <path> | '<js>')"
  # --wait with an empty/whitespace-only check would silently skip the wait (the
  # flag path bypasses waitForReady's own validation). Reject it explicitly so a
  # shell-quoting bug (--wait "$MAYBE_EMPTY") surfaces as an error, not a wrong answer.
  if [[ $wait_set -eq 1 ]] && [[ ! "$wait" =~ [^[:space:]] ]]; then
    die "--wait needs a non-empty JS check expression (got whitespace only)"
  fi
  local sock; sock=$(resolve_socket "$id") || exit 1
  local timeout_json=""
  if [[ -n "$timeout" ]]; then
    [[ "$timeout" =~ ^[0-9]+$ ]] || die "--timeout must be a number of ms"
    timeout_json=", \"timeout\": $timeout"
  fi
  # Resolve the app key for the memory hook. If this instance was started with
  # --app, read the memory file and pass it in the payload so the driver can
  # expose it as `memory` in the eval context. Empty/no file → empty array.
  local mem_json=""
  local runfile
  if runfile=$(resolve_runfile_for "$id" 2>/dev/null); then
    local app
    app=$(grep -E '^APP=' "$runfile" 2>/dev/null | cut -d= -f2-)
    if [[ -n "$app" ]]; then
      local memfile="$MEMORY_DIR/$app.json"
      if [[ -f "$memfile" ]]; then
        # Compact to a single-line JSON array (the file is pretty-printed for
        # human readability; embedding multi-line JSON breaks the payload parse).
        # Validate first; skip silently if corrupt rather than crashing the eval.
        local compact
        compact=$(python3 -c "import json,sys; print(json.dumps(json.load(open(sys.argv[1]))))" "$memfile" 2>/dev/null) \
          && mem_json=", \"memory\": $compact"
      fi
    fi
  fi
  python3 - "$sock" "$code" "$timeout_json$mem_json" "$page" "$wait" <<'PY'
import socket, json, sys
sock_path, code, timeout_json, page_flag, wait_expr = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4] == "1", sys.argv[5]

def js_str_dq(s):
    """Escape a JS string literal body for double-quoted strings."""
    return s.replace('\\', '\\\\').replace('"', '\\"').replace('\n', '\\n')

if page_flag:
    # --page: wrap ONLY the body in evalInPage. The wait call (if any) stays in
    # Node context where waitForReady is a native helper. This is the key fix:
    # previously the whole body (including the wait) was wrapped, so waitForReady
    # wasn't in scope inside evalInPage.
    stripped = code.strip()
    needs_iife = (';' in stripped) or stripped.startswith('return') or stripped.startswith('{') or stripped.startswith('await')
    inner = js_str_dq(code)
    body = f'return evalInPage("(async () => {{ {inner} }})()")' if needs_iife else f'return evalInPage("{inner}")'
    if wait_expr:
        wait_inner = js_str_dq(wait_expr)
        # Cap the wait timeout below the body timeout so the wait's own error
        # fires first — otherwise a short --timeout produces a misleading
        # "eval body timed out" when it was the --wait check that failed.
        wait_to = 15000
        if timeout_json:
            try:
                inner = timeout_json.strip().lstrip(',').strip()
                body_ms = json.loads('{' + inner + '}')['timeout']
                wait_to = max(500, min(15000, body_ms - 500))
            except Exception:
                pass
        code = f'await waitForReady({{ check: "{wait_inner}", timeout: {wait_to}, hint: "--wait check" }});\n{body}'
    else:
        code = body
elif wait_expr:
    # --wait without --page: prepend the wait call to the body (both in Node context).
    wait_inner = js_str_dq(wait_expr)
    wait_to = 15000
    if timeout_json:
        try:
            inner = timeout_json.strip().lstrip(',').strip()
            body_ms = json.loads('{' + inner + '}')['timeout']
            wait_to = max(500, min(15000, body_ms - 500))
        except Exception:
            pass
    code = f'await waitForReady({{ check: "{wait_inner}", timeout: {wait_to}, hint: "--wait check" }});\n' + code

# Default client socket timeout 120s; if the caller set a body timeout, match it
# (plus a 10s grace so the driver's own timeout error arrives before the socket's).
client_timeout = 120
if timeout_json:
    try:
        inner = timeout_json.strip().lstrip(',').strip()
        body_ms = json.loads('{' + inner + '}')['timeout']
        client_timeout = max(120, (body_ms // 1000) + 10)
    except Exception:
        pass
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(client_timeout)
try:
    s.connect(sock_path)
except (ConnectionRefusedError, FileNotFoundError) as e:
    sys.stdout.write(json.dumps({"error": f"driver socket refused ({e}) — driver not running? run chad-browser list, then chad-browser down + up to recover"}) + "\n")
    sys.exit(1)
payload = json.dumps({"eval": code})
if timeout_json:
    payload = payload[:-1] + timeout_json + "}"
s.sendall((payload + "\n").encode())
buf = b""
while b"\n" not in buf:
    chunk = s.recv(65536)
    if not chunk:
        break
    buf += chunk
sys.stdout.write(buf.decode() if buf else '{"error":"no response from driver"}\n')
PY
}

# Like eval but reads the JS from a file (multi-line scripts). Forwards all
# eval flags (--page, --wait, --timeout, --id/--name) so the file's JS runs in
# the same context you'd get from an inline eval with those flags.
cmd_script() {
  local id="" file="" timeout="" page="" wait=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id|--name|-n) id=$2; shift 2;;
      --timeout|-t) timeout=$2; shift 2;;
      --page) page=1; shift;;
      --wait) wait=$2; shift 2;;
      *)       file=$1; shift;;
    esac
  done
  [[ -n "$file" ]] || die "usage: chad-browser script [--id <name|port|pid>] [--timeout <ms>] [--page] [--wait '<check>'] <file.js>"
  [[ -f "$file" || -p "$file" ]] || die "no such file: $file"
  local code; code=$(<"$file")
  local fwd=()
  [[ -n "$id" ]] && fwd+=(--id "$id")
  [[ -n "$timeout" ]] && fwd+=(--timeout "$timeout")
  [[ -n "$page" ]] && fwd+=(--page)
  [[ -n "$wait" ]] && fwd+=(--wait "$wait")
  cmd_eval "${fwd[@]}" "$code"
}

# Interactive REPL — line-buffered stdin → eval, one response per line.
cmd_repl() {
  local id=""
  case "${1:-}" in
    --id|--name|-n) id=$2; shift 2;;
  esac
  local sock; sock=$(resolve_socket "$id") || exit 1
  echo "chad-browser repl → $sock  (.exit or Ctrl-D to exit)"
  local line
  while IFS= read -r -e -p "> " line; do
    case "$line" in
      .exit|.quit|.q|exit|quit) echo; return 0;;
    esac
    [[ -z "$line" ]] && continue
    if [[ -n "$id" ]]; then
      cmd_eval --id "$id" "$line"
    else
      cmd_eval "$line"
    fi
  done
  echo
}

cmd_gc() {
  ensure_dirs
  local f d
  for f in "$RUNDIR"/*.env; do
    [[ -e "$f" ]] || continue
    # shellcheck disable=SC1090
    (
      source "$f"
      if ! kill -0 "$PID" 2>/dev/null; then
        [[ -n "${DRIVER_PID:-}" ]] && kill "$DRIVER_PID" 2>/dev/null || true
        [[ -n "${SOCKET:-}" ]] && { pkill -f "driver.mjs.*${SOCKET}" 2>/dev/null || true; rm -f "$SOCKET" 2>/dev/null || true; }
        rm -rf "$PROFILE"; rm -f "$f"
        echo "reaped $NAME (port $PORT)"
      fi
    )
  done
  # Reap orphan driver processes. Two cases:
  #  (a) socket file gone (wedged driver outlived its instance) — the original case
  #  (b) socket file present but NO runfile references it (concurrent-up race orphan)
  local live_sockets
  live_sockets=$(grep -hE '^SOCKET=' "$RUNDIR"/*.env 2>/dev/null | cut -d= -f2- || true)
  while IFS= read -r dpid; do
    [[ -n "$dpid" ]] || continue
    local cmdline sock_arg
    cmdline=$(tr '\0' ' ' < "/proc/$dpid/cmdline" 2>/dev/null) || continue
    case "$cmdline" in
      *driver.mjs*)
        sock_arg=$(printf '%s' "$cmdline" | grep -oE '/run/user/[0-9]+/chad-browser/[^ ]+\.sock' | head -1)
        [[ -n "$sock_arg" ]] || continue
        # Reap if socket file is gone, OR if no live runfile claims this socket.
        if [[ ! -e "$sock_arg" ]] || ! grep -qF "$sock_arg" <<<"$live_sockets"; then
          kill "$dpid" 2>/dev/null && echo "reaped orphan driver $dpid (socket $sock_arg unowned)"
          [[ -e "$sock_arg" ]] && rm -f "$sock_arg" 2>/dev/null || true
        fi
        ;;
    esac
  done < <(pgrep -f 'driver.mjs' 2>/dev/null)
  # Reap orphan Chromium processes whose --user-data-dir points into EPHEM_ROOT
  # but no live runfile references that profile. Catches concurrent-up race orphans
  # that the runfile-keyed sweep above can't see.
  local live_profiles
  live_profiles=$(grep -hE '^PROFILE=' "$RUNDIR"/*.env 2>/dev/null | cut -d= -f2- || true)
  while IFS= read -r cpid; do
    [[ -n "$cpid" ]] || continue
    local cmdline prof_arg
    cmdline=$(tr '\0' ' ' < "/proc/$cpid/cmdline" 2>/dev/null) || continue
    prof_arg=$(printf '%s' "$cmdline" | grep -oE -- "--user-data-dir=[^ ]*" | head -1 | cut -d= -f2-)
    [[ -n "$prof_arg" ]] || continue
    case "$prof_arg" in
      "$EPHEM_ROOT"/*)
        if ! grep -qF "$prof_arg" <<<"$live_profiles"; then
          kill "$cpid" 2>/dev/null && echo "reaped orphan chromium $cpid (profile $prof_arg unowned)"
        fi
        ;;
    esac
  done < <(pgrep -f 'remote-debugging-port' 2>/dev/null)
  for d in "$EPHEM_ROOT"/*; do
    [[ -d "$d" ]] || continue
    if ! grep -qrF "PROFILE=$d" "$RUNDIR" 2>/dev/null; then rm -rf "$d"; echo "removed orphan $d"; fi
  done
}

cmd_probe() {
  # Probe one or more URLs for a live HTTP server. Expands a {PORT..PORT2} range
  # or a comma list in the host portion. Prints the first URL that responds, with
  # status code. Helps agents stop guessing which localhost port the dev server
  # is on — a top source of wasted turns in multi-instance workflows.
  local url=${1:-} code
  [[ -n "$url" ]] || die "usage: chad-browser probe <url>  (url may contain {8080..8090} or {8080,8081})"
  # Expand a single {start..end} or {a,b,c} brace in the URL.
  local urls=()
  if [[ "$url" =~ \{([0-9]+)\.\.([0-9]+)\} ]]; then
    local lo=${BASH_REMATCH[1]} hi=${BASH_REMATCH[2]} p
    for ((p=lo; p<=hi; p++)); do urls+=("${url/\{*$lo..\$hi\}/$p}"); done
    # The above substitution is fragile; do it the robust way:
    urls=()
    local prefix="${url%%\{*}" suffix="${url#*\}}"
    suffix="${suffix#*\}}"
    for ((p=lo; p<=hi; p++)); do urls+=("${prefix}${p}${suffix}"); done
  elif [[ "$url" =~ \{([^}]*)\} ]]; then
    local brace=${BASH_REMATCH[1]}
    local prefix="${url%%\{*}" suffix="${url#*\}}"
    suffix="${suffix#*\}}"
    IFS=',' read -ra parts <<<"$brace"
    for p in "${parts[@]}"; do urls+=("${prefix}${p}${suffix}"); done
  else
    urls+=("$url")
  fi
  local u
  for u in "${urls[@]}"; do
    code=$(curl -sS -o /dev/null -w "%{http_code}" --max-time 2 "$u" 2>/dev/null) || code="down"
    if [[ "$code" != "000" && "$code" != "down" ]]; then
      printf '%s  %s\n' "$code" "$u"
      return 0
    fi
  done
  echo "no live server found among ${#urls[@]} URL(s)" >&2
  return 1
}

# --- memory hook -------------------------------------------------------------
# Memory lets agents that visit the same app share hard-won knowledge: which
# selectors work, where the dev server lives, how to wait for hydration, etc.
# Keyed by --app (set on `up`) so multiple dev-server ports collapse to one key.
# Falls back to hostname for prod sites when --app wasn't passed.
# Storage: $MEMORY_DIR/<key>.json — a flat array of strings.

memory_key_for_instance() {
  local runfile id_port id_name app
  runfile=$(resolve_mine 2>/dev/null || resolve_id "${1:-}" 2>/dev/null) || return 1
  [[ -n "$runfile" && -e "$runfile" ]] || return 1
  app=$(grep -E '^APP=' "$runfile" | cut -d= -f2-)
  if [[ -n "$app" ]]; then
    echo "$app"
    return 0
  fi
  # Fallback: derive a key from the hostname of the first URL the instance opened.
  # For prod sites (app.example.com) this gives a stable key across port-less URLs.
  echo "chad-browser: no --app set for this instance. Pass --app <name> on 'up', or use --app <name> on 'recall'/'remember'." >&2
  return 1
}

cmd_remember() {
  local app="" fact="" json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --app)  app=$2; shift 2;;
      --json) json=1; shift;;
      -*)     die "unknown option '$1' (see: chad-browser remember --help)";;
      *)      fact="${fact:+$fact }$1"; shift;;
    esac
  done
  [[ -n "$fact" ]] || die "usage: chad-browser remember [--app <name>] \"<fact>\""
  if [[ -z "$app" ]]; then
    app=$(memory_key_for_instance) || die "no --app set and no instance found for this shell (pass --app <name> explicitly)"
  fi
  [[ "$app" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]] \
    || die "invalid app key '$app': use letters, digits, ., _, - (max 64 chars)"
  mkdir -p "$MEMORY_DIR"
  local file="$MEMORY_DIR/$app.json" lockfile="$MEMORY_DIR/$app.lock"
  # Atomic read-modify-write via flock. Without this, N parallel `remember`
  # calls on the same app clobber each other (each reads the old file, appends
  # its fact, writes back — last writer wins, N-1 facts silently lost).
  (
    flock -x 200 || die "could not acquire memory lock for '$app'"
    local arr
    if [[ -f "$file" ]]; then
      arr=$(cat "$file" 2>/dev/null || echo '[]')
    else
      arr='[]'
    fi
    local new
    new=$(printf '%s' "$arr" | python3 -c "
import json, sys
arr = json.load(sys.stdin)
fact = sys.argv[1]
if fact in arr:
    arr.remove(fact)
arr.insert(0, fact)
arr = arr[:50]
print(json.dumps(arr, indent=2))
" "$fact" 2>/dev/null) || die "failed to update memory for '$app' (file may be corrupt: $file)"
    printf '%s\n' "$new" > "$file"
    if [[ $json -eq 1 ]]; then
      printf '%s\n' "$new"
    else
      echo "remembered for '$app': $fact"
    fi
  ) 200>"$lockfile"
}

cmd_recall() {
  local app="" json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --app)  app=$2; shift 2;;
      --json) json=1; shift;;
      -*)     die "unknown option '$1' (see: chad-browser recall --help)";;
      *)      die "unexpected argument '$1' (usage: chad-browser recall [--app <name>] [--json])";;
    esac
  done
  if [[ -z "$app" ]]; then
    app=$(memory_key_for_instance 2>/dev/null) || {
      die "no --app set and no instance found for this shell (pass --app <name> explicitly)"
    }
  fi
  [[ "$app" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]] \
    || die "invalid app key '$app': use letters, digits, ., _, - (max 64 chars)"
  local file="$MEMORY_DIR/$app.json"
  if [[ ! -f "$file" ]]; then
    if [[ $json -eq 1 ]]; then echo '[]'; else echo "(no memories yet for '$app')"; fi
    return 0
  fi
  if [[ $json -eq 1 ]]; then
    cat "$file"
  else
    echo "memories for '$app':"
    cat "$file" | python3 -c "
import json, sys
arr = json.load(sys.stdin)
for i, fact in enumerate(arr, 1):
    print(f'  {i}. {fact}')
if not arr:
    print('  (none)')
"
  fi
}

cmd_info() {
  echo "BIN       $BIN -> $(command -v "$BIN" 2>/dev/null || echo MISSING)"
  echo "BASE      $BASE"
  echo "RUNDIR    $RUNDIR"
  echo "EPHEM     $EPHEM_ROOT"
  echo "SOCKDIR   $SOCKDIR"
  echo "DRIVER    $DRIVER -> $([[ -f "$DRIVER" ]] && echo present || echo MISSING)"
  echo "NODE      $(command -v node 2>/dev/null || echo MISSING)"
  echo "PORTS     $CB_PORT_MIN-$CB_PORT_MAX"
  echo "HEADLESS  ${CB_HEADLESS:-0 (headed by default)}"
  echo "BASE OPEN $([[ -e "$BASE/DevToolsActivePort" || -L "$BASE/SingletonLock" ]] && echo yes || echo no)"
}

usage() {
  sed -n '3,31p' "$0"
}

case "${1:-}" in
  up)              shift; cmd_up "$@";;
  down|stop)       shift; cmd_down "$@";;
  list|ls)         shift; cmd_list "$@";;
  cdp|ws)          shift; cmd_cdp "$@";;
  eval)            shift; cmd_eval "$@";;
  script)          shift; cmd_script "$@";;
  repl)            shift; cmd_repl "$@";;
  gc)              shift; cmd_gc "$@";;
  probe)           shift; cmd_probe "$@";;
  remember)        shift; cmd_remember "$@";;
  recall)          shift; cmd_recall "$@";;
  info)            cmd_info;;
  ""|-h|--help)    usage;;
  *) die "unknown command '$1' (try: chad-browser --help)";;
esac
